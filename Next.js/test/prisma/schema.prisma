model code_construction_dept {
  code String @id @db.VarChar(3)
  name String
}

model code_construction_field {
  code String @id @db.VarChar(3)
  name String
}

model standard_link {
  gid        Int                      @id @default(autoincrement())
  link_id    String?
  f_node     String?
  t_node     String?
  lanes      BigInt?
  road_rank  String?                  @db.VarChar(3)
  road_type  String?                  @db.VarChar(3)
  road_no    String?                  @db.VarChar(5)
  road_name  String?
  road_use   String?                  @db.VarChar(1)
  multi_link String?                  @db.VarChar(1)
  connect    String?                  @db.VarChar(3)
  max_spd    BigInt?
  rest_veh   String?                  @db.VarChar(3)
  rest_w     BigInt?
  rest_h     BigInt?
  c_its      String?                  @db.VarChar(1)
  length     Decimal?                 @db.Decimal
  updatedate String?                  @db.VarChar(8)
  remark     String?
  hist_type  String?                  @db.VarChar(8)
  histremark String?
  geom       Unsupported("geometry")?

  @@index([geom], type: Gist)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id         Decimal  @id @default(dbgenerated("nextval('cart_items_id_seq'::regclass)")) @db.Decimal(20, 0)
  cart_id    Decimal  @db.Decimal(20, 0)
  product_id Decimal  @db.Decimal(20, 0)
  quantity   Decimal  @db.Decimal(20, 0)
  unit_price Decimal  @db.Decimal(12, 2)
  option_name String? @db.VarChar(200)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@unique([cart_id, product_id, option_name], map: "uq_cart_product_option")
  @@index([cart_id], map: "idx_cart_items_cart_id")
  @@index([product_id], map: "idx_cart_items_product_id")
}

model carts {
  id         Decimal  @id @default(dbgenerated("nextval('carts_id_seq'::regclass)")) @db.Decimal(20, 0)
  user_id    Decimal  @db.Decimal(20, 0)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@index([user_id], map: "idx_carts_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id           Decimal  @id @default(dbgenerated("nextval('order_items_id_seq'::regclass)")) @db.Decimal(20, 0)
  order_id     Decimal  @db.Decimal(20, 0)
  product_id   Decimal  @db.Decimal(20, 0)
  product_name String   @db.VarChar(200)
  unit_price   Decimal  @db.Decimal(12, 2)
  quantity     Decimal  @db.Decimal(20, 0)
  total_price  Decimal  @db.Decimal(12, 2)
  option_name  String?  @db.VarChar(200)
  tracking_number String? @db.VarChar(100)
  item_status  String   @default("PAID") @db.VarChar(30)
  created_at   DateTime @default(now()) @db.Timestamp(6)

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_id], map: "idx_order_items_product_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id                   Decimal  @id @default(dbgenerated("nextval('orders_id_seq'::regclass)")) @db.Decimal(20, 0)
  user_id              Decimal  @db.Decimal(20, 0)
  order_number         String   @unique @db.VarChar(50)
  order_status         String   @default("PENDING") @db.VarChar(30)
  total_product_amount Decimal  @default(0) @db.Decimal(12, 2)
  shipping_fee         Decimal  @default(0) @db.Decimal(12, 2)
  discount_amount      Decimal  @default(0) @db.Decimal(12, 2)
  final_amount         Decimal  @default(0) @db.Decimal(12, 2)
  receiver_name        String?  @db.VarChar(100)
  receiver_phone       String?  @db.VarChar(30)
  shipping_address     String?
  shipping_message     String?
  is_gift              Boolean  @default(false)
  ordered_at           DateTime @default(now()) @db.Timestamp(6)
  created_at           DateTime @default(now()) @db.Timestamp(6)
  updated_at           DateTime @default(now()) @db.Timestamp(6)

  @@index([ordered_at], map: "idx_orders_ordered_at")
  @@index([order_status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id             Decimal   @id @default(dbgenerated("nextval('payments_id_seq'::regclass)")) @db.Decimal(20, 0)
  user_id        Decimal   @db.Decimal(20, 0)
  order_id       Decimal   @db.Decimal(20, 0)
  payment_key    String?   @unique @db.VarChar(100)
  payment_method String    @db.VarChar(30)
  payment_status String    @default("READY") @db.VarChar(30)
  amount         Decimal   @db.Decimal(12, 2)
  approved_at    DateTime? @db.Timestamp(6)
  failed_at      DateTime? @db.Timestamp(6)
  cancelled_at   DateTime? @db.Timestamp(6)
  fail_reason    String?
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @default(now()) @db.Timestamp(6)

  @@index([order_id], map: "idx_payments_order_id")
  @@index([payment_key], map: "idx_payments_payment_key")
  @@index([payment_status], map: "idx_payments_status")
  @@index([user_id], map: "idx_payments_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model products {
  id          Decimal  @id @default(dbgenerated("nextval('products_id_seq'::regclass)")) @db.Decimal(20, 0)
  name        String   @db.VarChar(200)
  description String?
  price       Decimal  @db.Decimal(12, 2)
  stock       Decimal  @default(0) @db.Decimal(20, 0)
  sku         String?  @unique @db.VarChar(100)
  image_data  Bytes?
  image_type  String?  @db.VarChar(50)
  category    String?  @default("etc") @db.VarChar(100)
  is_active   Boolean  @default(true)
  seller_id   Int?     // 외래키 제약조건 없이 단순 컬럼으로 추가
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  @@index([is_active], map: "idx_products_is_active")
  @@index([name], map: "idx_products_name")
}

model product_options {
  id          Int      @id @default(autoincrement())
  product_id  Decimal  @db.Decimal(20, 0)
  option_name String   @db.VarChar(200)
  stock       Decimal  @default(0) @db.Decimal(20, 0)
  add_price   Decimal  @default(0) @db.Decimal(12, 2)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  @@index([product_id], map: "idx_product_options_product_id")
}

model wishlists {
  id         Int      @id @default(autoincrement())
  user_id    Decimal  @db.Decimal(20, 0)
  product_id Decimal  @db.Decimal(20, 0)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@unique([user_id, product_id], map: "uq_wishlists_user_product")
  @@index([user_id], map: "idx_wishlists_user_id")
  @@index([product_id], map: "idx_wishlists_product_id")
}

model product_reviews {
  id         Int      @id @default(autoincrement())
  user_id    Decimal  @db.Decimal(20, 0)
  product_id Decimal  @db.Decimal(20, 0)
  rating     Int      @default(5)
  content    String   @db.Text
  image_data Bytes?
  image_type String?  @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@index([product_id], map: "idx_product_reviews_product_id")
  @@index([user_id], map: "idx_product_reviews_user_id")
}

model coupons {
  id               Int      @id @default(autoincrement())
  code             String   @unique @db.VarChar(50)
  name             String   @db.VarChar(200)
  discount_type    String   @db.VarChar(20) // "PERCENT" | "AMOUNT"
  discount_value   Decimal  @db.Decimal(12, 2)
  min_order_amount Decimal  @default(0) @db.Decimal(12, 2)
  valid_until      DateTime @db.Timestamp(6)
  created_at       DateTime @default(now()) @db.Timestamp(6)
}

model user_coupons {
  id         Int      @id @default(autoincrement())
  user_id    Int
  coupon_id  Int
  is_used    Boolean  @default(false)
  used_at    DateTime? @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([user_id])
  @@index([coupon_id])
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(200)
  message    String   @db.Text
  link       String?  @db.VarChar(500)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([user_id])
  @@index([is_read])
}

model flash_sales {
  id               Int      @id @default(autoincrement())
  product_id       Int
  discount_percent Int
  start_time       DateTime @db.Timestamp(6)
  end_time         DateTime @db.Timestamp(6)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamp(6)

  @@index([product_id])
  @@index([end_time])
}

model seller_follows {
  id          Int      @id @default(autoincrement())
  follower_id Int
  seller_id   Int
  created_at  DateTime @default(now()) @db.Timestamp(6)

  @@unique([follower_id, seller_id])
  @@index([seller_id])
}

model review_helpful {
  id         Int      @id @default(autoincrement())
  review_id  Int
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@unique([review_id, user_id])
  @@index([review_id])
}

model product_price_history {
  id         Int      @id @default(autoincrement())
  product_id Int
  price      Decimal  @db.Decimal(12, 2)
  recorded_at DateTime @default(now()) @db.Timestamp(6)

  @@index([product_id])
  @@index([recorded_at])
}

