generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model chat {
  id        Int     @id @default(autoincrement())
  recepient String? @db.VarChar(1000)
  sender    String? @db.VarChar(1000)
  content   String? @db.VarChar(1000)
  image     Bytes?
}

model link {
  sectionid Int
  linkid    String   @db.VarChar(100)
  seq       Decimal? @db.Decimal

  @@id([sectionid, linkid])
}

model post {
  id        Int       @id @default(autoincrement())
  title     String?   @db.VarChar(1000)
  content   String?   @db.VarChar(1000)
  createdat DateTime? @db.Timestamp(6)
  updatedat DateTime? @db.Timestamp(6)
  image     Bytes?
  postview  Int?      @default(0)
  writer    String?   @db.VarChar(1000)
}

model qna {
  id        Int       @id @default(autoincrement())
  title     String?   @db.VarChar(1000)
  content   String?   @db.VarChar(1000)
  createdat DateTime? @db.Timestamp(6)
  image     Bytes?
  qnaview   Int?      @default(0)
  isend     Int?      @default(0)
  writer    String?   @db.VarChar(1000)
}

model answer {
  id         Int       @id @default(autoincrement())
  title      String?   @db.VarChar(1000)
  content    String?   @db.VarChar(1000)
  createdat  DateTime? @db.Timestamp(6)
  image      Bytes?
  questionid Int?
  writer     String?   @db.VarChar(1000)
}

model postcomment {
  id             Int     @id @default(autoincrement())
  postid         Int?
  commenttitle   String? @db.VarChar(1000)
  commentcontent String? @db.VarChar(1000)
  commentwriter  String? @db.VarChar(100)
}

model commentbycomment {
  id             Int     @id @default(autoincrement())
  upprcommentid  Int?
  commenttitle   String? @db.VarChar(1000)
  commentcontent String? @db.VarChar(1000)
  commentwriter  String? @db.VarChar(1000)
  postid         Int?
}

model postlike {
  id     Int     @id @default(autoincrement())
  postid Int?
  userid String? @db.VarChar(1000)
}

model questionlike {
  id         Int    @id @default(autoincrement())
  questionid Int
  userid     String @db.VarChar(1000)
}

model questionhate {
  id         Int    @id @default(autoincrement())
  questionid Int
  userid     String @db.VarChar(1000)
}

model answerlike {
  id         Int    @id @default(autoincrement())
  questionid Int
  userid     String @db.VarChar(1000)
  answerid   Int
}

model answerhate {
  id         Int    @id @default(autoincrement())
  questoinid Int
  userid     String @db.VarChar(1000)
  answerid   Int
}

model posthate {
  id     Int     @id @default(autoincrement())
  postid Int?
  userid String? @db.VarChar(1000)
}

model commentlike {
  id        Int     @id @default(autoincrement())
  commentid Int?
  userid    String? @db.VarChar(1000)
  postid    Int?
}

model commenthate {
  id        Int     @id @default(autoincrement())
  commentid Int?
  userid    String? @db.VarChar(1000)
  postid    Int?
}

model road {
  id       Int     @id @default(autoincrement())
  roadname String? @db.VarChar(600)
}

model section {
  id          Int     @id @default(autoincrement())
  linkid      String? @db.VarChar(4000)
  roadid      Int?
  sectionname String? @db.VarChar(100)
}

model users {
  id             Int              @id(map: "users_pkey1") @default(autoincrement())
  name           String?          @db.VarChar(100)
  naver_id       String?          @db.VarChar(3000)
  email          String?          @unique @db.VarChar(255)
  password       String?          @db.VarChar(255)
  ROLE           String?          @db.VarChar(1000)
  points         Decimal          @default(0) @db.Decimal(12, 2)
  refresh_tokens refresh_tokens[]
}

model point_logs {
  id          Int      @id @default(autoincrement())
  user_id     Int
  amount      Decimal  @db.Decimal(12, 2)
  description String   @db.VarChar(500)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  @@index([user_id])
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @db.VarChar(255)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@index([expires_at])
}

model busanpolyline {
  gid        Int                      @id @default(autoincrement())
  emd_cd     String?                  @db.VarChar(8)
  col_adm_se String?                  @db.VarChar(5)
  emd_nm     String?                  @db.VarChar(100)
  sgg_oid    Int?
  geom       Unsupported("geometry")?

  @@ignore
}

model busan_construction {
  gid              Int                      @id
  seq_no           BigInt?
  project_name     String?
  d_day            BigInt?
  total_days       BigInt?
  elapsed_days     BigInt?
  progress_rate    Decimal?
  plan_rate        Decimal?
  achievement_rate Decimal?
  field_code       String?                  @db.VarChar(10)
  location_text    String?
  start_date       DateTime?                @db.Date
  end_date         DateTime?                @db.Date
  dept_code        String?                  @db.VarChar(10)
  contact          String?
  budget_text      String?
  lat              Decimal?
  lon              Decimal?
  geom             Unsupported("geometry")?

  @@ignore
}

model busan_theme_travel {
  gid             Int                      @id
  fid             BigInt?
  content_id      BigInt?
  content_name    String?
  district_name   String?
  category_name   String?
  lat             Decimal?
  lon             Decimal?
  place_name      String?
  title           String?
  subtitle        String?
  main_content    String?
  address         String?
  address_detail  String?
  phone           String?
  homepage        String?
  transport_info  String?
  operating_days  String?
  closed_days     String?
  operating_hours String?
  fee_info        String?
  notice_info     String?
  image_url       String?
  thumbnail_url   String?
  detail_info     String?
  geom            Unsupported("geometry")?

  @@ignore
}

model busan_standard_node {
  fid        Int                      @id @default(autoincrement())
  geom       Unsupported("geometry")?
  node_id    String?                  @db.VarChar(10)
  node_type  String?                  @db.VarChar(3)
  node_name  String?                  @db.VarChar(50)
  turn_p     String?                  @db.VarChar(1)
  updatedate String?                  @db.VarChar(8)
  remark     String?                  @db.VarChar(30)
  hist_type  String?                  @db.VarChar(8)
  histremark String?                  @db.VarChar(30)

  @@map("busan_standard_node")
}

model busan_standard_link {
  fid        Int                      @id @default(autoincrement())
  geom       Unsupported("geometry")?
  link_id    String?                  @db.VarChar(10)
  f_node     String?                  @db.VarChar(10)
  t_node     String?                  @db.VarChar(10)
  lanes      BigInt?
  road_rank  String?                  @db.VarChar(3)
  road_type  String?                  @db.VarChar(3)
  road_no    String?                  @db.VarChar(5)
  road_name  String?                  @db.VarChar(30)
  road_use   String?                  @db.VarChar(1)
  multi_link String?                  @db.VarChar(1)
  connect    String?                  @db.VarChar(3)
  max_spd    BigInt?
  rest_veh   String?                  @db.VarChar(3)
  rest_w     BigInt?
  rest_h     BigInt?
  c_its      String?                  @db.VarChar(1)
  length     Float?
  updatedate String?                  @db.VarChar(8)
  remark     String?                  @db.VarChar(30)
  hist_type  String?                  @db.VarChar(8)
  histremark String?                  @db.VarChar(30)

  @@map("busan_standard_link")
}

model link_speed_history {
  id          Int      @id @default(autoincrement())
  link_id     String   @db.VarChar(20)
  speed       Float
  recorded_at DateTime @default(now()) @db.Timestamp(6)

  @@index([link_id, recorded_at])
}

